# Base URL of the Nordlys api-gateway. Frontend reads everything through it.
# In dev, point to the gateway running on the host:
#   VITE_API_URL=http://localhost:3000
# In docker compose with the frontend container behind a reverse proxy:
#   VITE_API_URL=/api
#
# Note: the API client (src/lib/api.ts) appends /v1 automatically for all
# domain endpoints. This variable should point to the gateway root — do NOT
# include /v1 here.
VITE_API_URL=http://localhost:3000
